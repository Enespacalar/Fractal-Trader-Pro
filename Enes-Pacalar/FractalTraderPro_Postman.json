				{
					"name": "1. Kayıt Ol (POST)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"username\": \"enespacalar\",\n    \"password\": \"Sifre123!\"\n}"},
						"url": {"raw": "https://fractal-trader-api.onrender.com/api/v1/users/register", "protocol": "https", "host": ["fractal-trader-api", "onrender", "com"], "path": ["api", "v1", "users", "register"]}
					}
				},
				{
					"name": "2. Giriş Yap (POST)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"username\": \"enespacalar\",\n    \"password\": \"Sifre123!\"\n}"},
