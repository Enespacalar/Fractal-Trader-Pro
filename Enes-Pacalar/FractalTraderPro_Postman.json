						"body": {"mode": "raw", "raw": "{\n    \"old_password\": \"Sifre123!\",\n    \"new_password\": \"YeniSifre456!\"\n}"},
						"url": {"raw": "https://fractal-trader-api.onrender.com/api/v1/users/password", "protocol": "https", "host": ["fractal-trader-api", "onrender", "com"], "path": ["api", "v1", "users", "password"]}
